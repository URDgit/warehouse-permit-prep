# =====================================================================
#  Environment variables
# =====================================================================
#  Copy this file to ".env.local" for local dev, and set the same values in
#  Vercel (Project → Settings → Environment Variables) for the live site.
#
#  Leave these BLANK to run the app in local-only mode (no login; data stays
#  in the browser / on disk). Fill them in to turn on hosted accounts.
# =====================================================================

# From Supabase: Project → Settings → API.
# The anon key is safe to expose publicly (security is enforced by RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to require sign-in (signed-out visitors go to /login).
# Leave blank/unset until per-account data is wired up and verified.
REQUIRE_AUTH=
